// Duraforge UK — database schema
// Real Postgres via Prisma. Local dev uses Homebrew Postgres; production swaps
// DATABASE_URL for a hosted provider (Supabase / Neon / Railway).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A B2B trade customer (or an admin staff member).
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  companyName  String
  vatNumber    String?
  phone        String
  role         Role     @default(CUSTOMER)

  // Delivery address
  addressLine1 String
  addressLine2 String?
  city         String
  county       String?
  postcode     String

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders       Order[]

  // NextAuth relations (reserved for future magic-link / OAuth)
  accounts     Account[]
  sessions     Session[]
}

enum Role {
  CUSTOMER
  ADMIN
}

/// A placed order. Cost columns are NEVER stored here — sale price only.
model Order {
  id            String        @id @default(cuid())
  orderNumber   String        @unique
  user          User          @relation(fields: [userId], references: [id])
  userId        String
  companyName   String
  email         String
  status        OrderStatus   @default(RECEIVED)

  subtotalExVat Float
  vatAmount     Float
  totalIncVat   Float
  paymentMethod PaymentMethod

  // Address snapshot at time of order
  shipLine1     String
  shipLine2     String?
  shipCity      String
  shipCounty    String?
  shipPostcode  String

  notes         String?
  carrier       String?
  trackingNumber String?
  statusUpdatedAt DateTime @default(now())
  createdAt     DateTime      @default(now())

  lineItems     OrderLineItem[]
  statusEvents  OrderStatusEvent[]

  @@index([userId])
  @@index([status])
}

model OrderStatusEvent {
  id        String      @id @default(cuid())
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())

  @@index([orderId])
}

/// Product catalogue — cost columns are ADMIN ONLY and must never reach customer APIs.
model Product {
  id               String   @id @default(cuid())
  sku              String   @unique
  partCode         String
  name             String
  brand            String
  brandSlug        String
  model            String
  position         String
  material         String
  rodMm            Float
  boreMm           Float
  heightMm         Float
  hardnessShoreA   Int
  tempMinC         Int
  tempMaxC         Int
  pressureBar      Int
  contents         Json
  fits             Json
  crossRefs        Json
  salePriceExVat   Float
  fpePrice         Float
  purchasePriceInr Float
  purchasePriceGbp Float
  landingPriceGbp  Float
  stockQty         Int
  madeIn           String   @default("India")
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([brandSlug])
  @@index([isActive])
}

enum EnquiryStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

/// Inbound contact / trade enquiry from the website.
model Enquiry {
  id          String        @id @default(cuid())
  name        String
  companyName String?
  email       String
  phone       String?
  message     String
  status      EnquiryStatus @default(NEW)
  createdAt   DateTime      @default(now())
  readAt      DateTime?

  @@index([status])
  @@index([createdAt])
}

model OrderLineItem {
  id             String @id @default(cuid())
  order          Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId        String
  sku            String
  name           String
  quantity       Int
  unitPriceExVat Float

  @@index([orderId])
}

enum OrderStatus {
  RECEIVED
  PICKING
  PACKED
  DESPATCHED
  DELIVERED
}

enum PaymentMethod {
  CARD
  BACS
}

// ---------------------------------------------------------------------------
// NextAuth (Auth.js) models — reserved for future OAuth / magic-link sign-in.
// Credentials login currently uses JWT sessions and does not populate these.
// ---------------------------------------------------------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
