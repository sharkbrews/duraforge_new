// Duraforge UK — database schema
// Real Postgres via Prisma. Local dev uses Homebrew Postgres; production swaps
// DATABASE_URL for a hosted provider (Supabase / Neon / Railway).

generator client {
  provider      = "prisma-client-js"
  // Vercel runs on Amazon Linux — include this target so Prisma works in production.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A B2B trade customer (or an admin staff member).
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  companyName  String
  vatNumber    String?
  phone        String
  role         Role     @default(CUSTOMER)

  // Admin security (Stage 3.5)
  mfaSecret          String?
  mfaEnabled         Boolean @default(false)
  mustChangePassword Boolean @default(false)

  // Loyalty (Stage 4)
  duraCoinsBalance Int      @default(0)
  isProMember      Boolean  @default(false)
  lastSpinMonth    String?  // "YYYY-MM" — one spin per calendar month

  // Delivery address
  addressLine1 String
  addressLine2 String?
  city         String
  county       String?
  postcode     String

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders       Order[]
  coinLedger   DuraCoinLedger[]
  badges       UserBadge[]
  spinResults  SpinResult[]

  // NextAuth relations (reserved for future magic-link / OAuth)
  accounts     Account[]
  sessions     Session[]
}

enum Role {
  CUSTOMER
  ADMIN
}

/// A placed order. Cost columns are NEVER stored here — sale price only.
model Order {
  id            String        @id @default(cuid())
  orderNumber   String        @unique
  user          User          @relation(fields: [userId], references: [id])
  userId        String
  companyName   String
  email         String
  status        OrderStatus   @default(RECEIVED)

  subtotalExVat Float
  vatAmount     Float
  totalIncVat   Float
  paymentMethod PaymentMethod

  // Address snapshot at time of order
  shipLine1     String
  shipLine2     String?
  shipCity      String
  shipCounty    String?
  shipPostcode  String

  notes         String?
  carrier       String?
  trackingNumber String?
  statusUpdatedAt DateTime @default(now())
  createdAt     DateTime      @default(now())

  lineItems     OrderLineItem[]
  statusEvents  OrderStatusEvent[]

  @@index([userId])
  @@index([status])
}

model OrderStatusEvent {
  id        String      @id @default(cuid())
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())

  @@index([orderId])
}

/// Product catalogue — cost columns are ADMIN ONLY and must never reach customer APIs.
model Product {
  id               String   @id @default(cuid())
  sku              String   @unique
  partCode         String
  name             String
  brand            String
  brandSlug        String
  model            String
  position         String
  material         String
  rodMm            Float
  boreMm           Float
  heightMm         Float
  hardnessShoreA   Int
  tempMinC         Int
  tempMaxC         Int
  pressureBar      Int
  contents         Json
  fits             Json
  crossRefs        Json
  salePriceExVat   Float
  fpePrice         Float
  purchasePriceInr Float
  purchasePriceGbp Float
  landingPriceGbp  Float
  stockQty         Int
  madeIn           String   @default("India")
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([brandSlug])
  @@index([isActive])
}

enum EnquiryStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

/// Inbound contact / trade enquiry from the website.
model Enquiry {
  id          String        @id @default(cuid())
  name        String
  companyName String?
  email       String
  phone       String?
  message     String
  status      EnquiryStatus @default(NEW)
  createdAt   DateTime      @default(now())
  readAt      DateTime?

  @@index([status])
  @@index([createdAt])
}

model OrderLineItem {
  id             String @id @default(cuid())
  order          Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId        String
  sku            String
  name           String
  quantity       Int
  unitPriceExVat Float

  @@index([orderId])
}

enum OrderStatus {
  RECEIVED
  PICKING
  PACKED
  DESPATCHED
  DELIVERED
}

enum PaymentMethod {
  CARD
  BACS
}

// ---------------------------------------------------------------------------
// NextAuth (Auth.js) models — reserved for future OAuth / magic-link sign-in.
// Credentials login currently uses JWT sessions and does not populate these.
// ---------------------------------------------------------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// Admin action audit trail (Stage 3.5). Records who did what, when, from where.
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorEmail String?
  action     String
  detail     String?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([actorId])
}

/// DuraCoin earn/spend ledger — £1 spent (inc-VAT) = 1 coin.
model DuraCoinLedger {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  amount    Int      // positive = earn, negative = spend/adjust
  reason    String
  orderId   String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

/// Trade achievement badges earned by customers.
model UserBadge {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  badgeKey  String
  earnedAt  DateTime @default(now())

  @@unique([userId, badgeKey])
  @@index([userId])
}

/// Spin-the-wheel prize log (one spin per calendar month).
model SpinResult {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  prizeKey  String
  prizeLabel String
  createdAt DateTime @default(now())

  @@index([userId])
}

/// Marketing campaign landing pages (CMS-lite).
model Campaign {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  subtitle    String?
  body        String
  ctaLabel    String?
  ctaHref     String?
  isActive    Boolean   @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isActive])
}
