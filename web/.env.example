# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Postgres connection string.
#  - Local (Homebrew) example:  postgresql://<your-mac-username>@localhost:5432/duraforge?schema=public
#  - Hosted (Supabase/Neon/Railway): paste the connection string they give you.
DATABASE_URL="postgresql://USER@localhost:5432/duraforge?schema=public"

# NextAuth / Auth.js secret used to sign session tokens.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="change-me-to-a-long-random-string"
# Required on Vercel (Auth.js trusts the host header from the platform proxy).
AUTH_TRUST_HOST="true"

# --- Admin security (Stage 3.5) ---

# Comma-separated IPs / addresses allowed to reach /admin and /api/admin.
# Leave EMPTY in local dev (all IPs allowed; loopback is always allowed).
# In production set to your office / VPN egress IPs, e.g. "203.0.113.10,198.51.100.5".
ADMIN_IP_ALLOWLIST=""

# Optional: initial admin login used by `npm run db:seed`.
# If omitted, the seed generates a random password and prints it once.
# The admin is always forced to change it + enrol MFA on first login.
ADMIN_EMAIL="admin@duraforge.co.uk"
ADMIN_INITIAL_PASSWORD=""

# --- Payments: Stripe (Stage 4b) ---
# Leave ALL blank for local dev → checkout uses the simulated (mock) flow.
# Fill with test keys (sk_test_… / pk_test_…) to exercise real Stripe locally.
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# From the Stripe dashboard webhook endpoint (whsec_…). Needed for /api/stripe/webhook.
STRIPE_WEBHOOK_SECRET=""

# --- Email marketing: Klaviyo (Stage 4b) ---
# When set, trackEmailEvent() posts events to Klaviyo. Blank = console log only.
KLAVIYO_API_KEY=""

# --- Company / invoicing ---
# Shown on VAT invoices once VAT registration completes.
COMPANY_VAT_NUMBER=""
